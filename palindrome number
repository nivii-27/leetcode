#include <stdbool.h>
bool isPalindrome(int x) {
    if (x < 0 || (x % 10 == 0 && x != 0)) {
        return false;
    }
    int reversedNum = 0;
    while (x > reversedNum) {
        int pop = x % 10;
        if (reversedNum > (2147483647 / 10)) return false;
        
        reversedNum = reversedNum * 10 + pop;
        x /= 10;
    }

    return x == reversedNum || x == reversedNum / 10;
}
