#include<stdio.h>
#include<stdlib.h>
#include<stdbool.h>
bool hasAlternatingBits(int n) {
    int bin[32];
    int i=0;
    if(n==0){
        return true;
    }
    while(n>0){
     int rem=n%2;
     bin[i]=rem;
     n=n/2;
     i++;
    }
    for(int j=i-1;j>0;j--){
        if(bin[j]==bin[j-1]){
            return false;
        }
    }
    return true;
}
